AUTHSDK_PATH=../authSDK-1.1.0
AUTH_BASE_URL=http://localhost:8000
TWA_AUTH_AUDIENCE=twa-api
TWA_AUTH_ENABLED=true
TWA_LOG_LEVEL=INFO
TWA_REQUEST_ID_HEADER=X-Request-ID
