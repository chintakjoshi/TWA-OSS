AUTH_REDIS_PORT=6380
TWA_SEED_STAFF_AUTH_USER_ID=
TWA_SEED_STAFF_EMAIL=
TWA_SEED_STAFF_PROVIDER_ROLE=admin

VITE_TWA_API_URL=http://localhost:9000
VITE_AUTH_BASE_URL=/_auth
VITE_AUTH_PROXY_TARGET=http://localhost:8000
