TWA_NOTIFICATION_EMAIL_ENABLED=true
TWA_SMTP_HOST=localhost
TWA_SMTP_PORT=1025
TWA_SMTP_TIMEOUT_SECONDS=10
TWA_EMAIL_FROM=notifications@localhost
DATABASE_URL=postgresql+psycopg://twa:twa@localhost:5432/twa
TWA_ENVIRONMENT=development
TWA_DEBUG=true
TWA_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
BACKEND_PORT=9000
JOBSEEKER_PORT=5173
EMPLOYER_PORT=5174
ADMIN_PORT=5175
ADMINER_PORT=8080
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
AUTH_SERVICE_PORT=8000
